# ---------------------------------------------------------------------------
# Environment variables for the Avito Plus microservices stack.
# Copy this file to ".env" and fill in real values. The ".env" file is
# git-ignored and must never be committed.
# ---------------------------------------------------------------------------

# CORS origin. Use "*" for local development.
ORIGIN="*"

# Public-facing domains of the frontend / backend
FRONTEND_DOMAIN="http://localhost:4000"
BACKEND_DOMAIN="http://localhost:3000"

# --- Service ports (used by docker-compose.dev.yml port mapping) ---
AUTH_PORT=8084
AVITO_PORT=8083
EMAIL_PORT=8086
GOOGLE_PORT=8081
MONGO_PORT=8090
TINKOFF_PORT=8087
VALIDATOR_PORT=3000
XML_PORT=8085  # served by the google service (no standalone xml service)
YANDEX_PORT=8082
CRON_PORT=8095
# Dozzle log viewer UI port
DOZZLE_PORT=6001

# --- Internal service hostnames (Docker network DNS = service name) ---
AUTH_HOST="http://auth:8084"
AVITO_HOST="http://avito:8083"
EMAIL_HOST="http://email:8086"
GOOGLE_HOST="http://google:8081"
MONGO_HOST="http://mongo-server:8090"
TINKOFF_HOST="http://tinkoff:8087"
VALIDATOR_HOST="http://localhost:3000"
XML_HOST="http://xml:8085"  # served by the google service (no standalone xml service)
YANDEX_HOST="http://yandex:8082"
CRON_HOST="http://cron:8095"

# --- MongoDB credentials (consumed by docker-compose + MONGO_URL) ---
MONGO_INITDB_ROOT_USERNAME="changeme"
MONGO_INITDB_ROOT_PASSWORD="changeme-strong-password"
MONGO_URL="mongodb://changeme:changeme-strong-password@mongo-db:27017"

# --- Auth (JWT) ---
JWT_SECRET="replace-with-a-long-random-hex-string"
JWT_EXPIRES_IN="30d"

# --- Email delivery (SendGrid) ---
SENDGRID_API_KEY="SG.replace_with_your_sendgrid_api_key"

# --- Google Sheets template / service account ---
# Spreadsheet + sheet ids used as a sample template
TABLE_SAMPLE="your_google_spreadsheet_id"
SHEET_SAMPLE="your_sheet_gid"
# Email that owns / receives shared spreadsheets
MANAGER_TABLE_EMAIL="service@your-domain.example"

# --- Tinkoff payments ---
TINKOFF_TERM_KEY="your_tinkoff_terminal_key"
TINKOFF_TERM_PASS="your_tinkoff_terminal_password"
TINKOFF_VALIDATE_TOKEN="your_tinkoff_webhook_validate_token"

# --- Yandex OAuth (Yandex Disk) ---
YANDEX_CLIENT_ID="your_yandex_oauth_client_id"
YANDEX_CLIENT_SECRET="your_yandex_oauth_client_secret"
