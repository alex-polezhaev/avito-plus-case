# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored and must never be committed.

# ---- Server ----
APP_IP=0.0.0.0
APP_PORT=3000
NODE_ENV=development
# Default log level for the application logger (trace|debug|info|warn|error)
LOG_LEVEL=info
# IANA timezone, e.g. Europe/Moscow
TZ=Europe/Moscow

# ---- Public URLs ----
FRONTEND_DOMAIN=http://localhost:5173
BACKEND_DOMAIN=http://localhost:3000

# ---- MongoDB ----
DB_CONNECTION_STRING=mongodb://localhost:27017/avito-plus
DBUSER=avito_plus
DBPASS=change_me
DBHOST=localhost
DBNAME=avito-plus

# ---- Auth (JWT) ----
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- Cron protection ----
# Shared secret required by every /cron/* endpoint.
# Send it as the `x-cron-secret` header or a `?secret=` query parameter.
CRON_SECRET=replace_with_a_long_random_string

# ---- Yandex.Disk OAuth ----
YANDEX_CLIENT_ID=your_yandex_oauth_client_id
YANDEX_CLIENT_SECRET=your_yandex_oauth_client_secret

# ---- Telegram bot (optional; bot starts only when this is set) ----
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ---- Tinkoff payments ----
TINKOFF_TERM_KEY=your_tinkoff_terminal_key
TINKOFF_TERM_PASS=your_tinkoff_terminal_password

# ---- NetAngels hosting (container restart script) ----
NET_ANGELS_TOKEN=your_netangels_api_token

# ---- SendGrid (transactional email) ----
SENDGRID_API_KEY=your_sendgrid_api_key

# ---- Google Sheets ----
# Email of the service account / manager that owns the spreadsheets.
MANAGER_TABLE_EMAIL=service-account@example.iam.gserviceaccount.com
# Template spreadsheet and sheet ids the engine clones for each new account.
TABLE_SAMPLE=your_template_spreadsheet_id
SHEET_SAMPLE=your_template_sheet_id

# Note: the Google service-account key itself is a JSON file, not an env var.
# Place it at server/services/Google/auth/auth.json (see auth.example.json).
